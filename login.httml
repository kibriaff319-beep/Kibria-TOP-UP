<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | KIBRIATOP UP</title>
    <style>
        body { background: #f4f7f6; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: sans-serif; margin: 0; }
        .box { background: #fff; padding: 30px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); width: 90%; max-width: 350px; text-align: center; }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: #1e3799; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; }
        a { color: #1e3799; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <div class="box">
        <h2>লগইন করুন</h2>
        <input type="email" placeholder="ইমেইল">
        <input type="password" placeholder="পাসওয়ার্ড">
        <button onclick="location.href='index.html'">লগইন</button>
        <p style="font-size:14px; margin-top:15px;">অ্যাকাউন্ট নেই? <a href="signup.html">সাইনআপ করুন</a></p>
    </div>
</body>
</html>
